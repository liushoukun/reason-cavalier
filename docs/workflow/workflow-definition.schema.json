{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reason-cavalier.local/schemas/workflow-definition.schema.json",
  "title": "WorkflowDefinition",
  "description": "Workflow 简化定义 Schema（均衡核心）：id/version/name/description/stages/transitions/gates。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "name", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "description": "工作流唯一标识，建议 kebab-case（小写字母、数字、连字符段）",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "description": "工作流定义本身的版本（如 1.0.0）， semver 或项目约定字符串"
    },
    "name": {
      "type": "string",
      "description": "人类可读名称"
    },
    "description": {
      "type": "string",
      "description": "工作流总体说明"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "description": "工作流阶段定义",
      "items": { "$ref": "#/$defs/stage" }
    },
    "transitions": {
      "type": "array",
      "description": "阶段间迁移规则",
      "items": { "$ref": "#/$defs/transition" }
    },
    "gates": {
      "type": "array",
      "description": "全局门禁定义",
      "items": { "$ref": "#/$defs/gate_rule" }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "key", "title", "purpose"],
      "properties": {
        "id": {
          "type": "string",
          "description": "stage 在文件内唯一 id，建议小写 kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "key": {
          "type": "string",
          "description": "stage 英文键，与文档、门禁引用一致（如 Spec、Plan）"
        },
        "title": {
          "type": "string",
          "description": "中文展示名，可含「阶段」等词"
        },
        "purpose": {
          "type": "string",
          "description": "本 stage 目的说明"
        },
        "inputs": {
          "type": "array",
          "description": "本阶段依赖输入",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "description": "本阶段约定产出",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "description": "阶段内步骤列表",
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "purpose"],
      "properties": {
        "id": {
          "type": "string",
          "description": "步骤唯一标识，建议 kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "步骤显示名"
        },
        "purpose": {
          "type": "string",
          "description": "步骤目标"
        },
        "inputs": {
          "type": "array",
          "description": "步骤输入项",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "description": "步骤产出项",
          "items": { "type": "string" }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_key", "to_key"],
      "properties": {
        "from_key": {
          "type": "string",
          "description": "起始 stage 的 key"
        },
        "to_key": { "type": "string", "description": "目标 stage 的 key" },
        "gate_id": {
          "type": "string",
          "description": "可选：引用 gates[].id"
        },
        "gate_note": {
          "type": "string",
          "description": "可选：门禁说明（人读）"
        }
      }
    },
    "gate_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "criteria"],
      "properties": {
        "id": {
          "type": "string",
          "description": "门禁 id，如 G1/G2/G3/G4",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "type": {
          "type": "string",
          "description": "门禁类型",
          "enum": ["STARTUP", "IMPLEMENTATION", "SUBMISSION", "DELIVERY", "CUSTOM"]
        },
        "criteria": {
          "type": "array",
          "description": "门禁判定条件列表",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
