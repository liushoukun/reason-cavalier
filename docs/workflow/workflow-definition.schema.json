{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reason-cavalier.local/schemas/workflow-definition.schema.json",
  "title": "WorkflowDefinition",
  "description": "Workflow 机读定义：主流程为 stages[] 声明顺序；门禁仅出现在 stage.gates[]，不作为顶层集合。语义与约束见 docs/workflow/index.md。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "name", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "description": "工作流唯一标识，建议 kebab-case",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "description": "工作流定义版本（如 1.0.0），semver 或项目约定字符串"
    },
    "name": {
      "type": "string",
      "description": "人类可读名称"
    },
    "description": {
      "type": "string",
      "description": "工作流总体说明（可选）"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "description": "阶段按数组顺序构成主流程 DAG：stages[i] -> stages[i+1]",
      "items": { "$ref": "#/$defs/stage" }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "purpose", "gates"],
      "properties": {
        "name": {
          "type": "string",
          "description": "阶段唯一标识，建议 kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "阶段显示名"
        },
        "purpose": {
          "type": "string",
          "description": "阶段目标"
        },
        "gates": {
          "type": "array",
          "description": "阶段门禁集合；每项为 gate_item（type + conditions[]）。判定语义：PASS / SOFT_FAIL / HARD_FAIL（见规范正文）",
          "items": { "$ref": "#/$defs/gate_item" }
        },
        "inputs": {
          "type": "array",
          "description": "阶段输入（可选）",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "description": "阶段产出（可选）",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "description": "阶段内步骤（可选）",
          "items": { "$ref": "#/$defs/step" }
        },
        "agents": {
          "type": "array",
          "description": "阶段执行主体，用于编排提示（可选）",
          "items": { "type": "string" }
        }
      }
    },
    "gate_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "conditions"],
      "properties": {
        "id": {
          "type": "string",
          "description": "门禁项可读 id（可选），如 G1",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "type": {
          "type": "string",
          "description": "门禁类型",
          "enum": ["STARTUP", "IMPLEMENTATION", "SUBMISSION", "DELIVERY", "CUSTOM"]
        },
        "conditions": {
          "type": "array",
          "description": "须逐条判定的条件清单（至少 1 条）",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "notes": {
          "type": "string",
          "description": "补充说明（可选）"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "purpose"],
      "properties": {
        "name": {
          "type": "string",
          "description": "步骤唯一标识，建议 kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "步骤显示名"
        },
        "purpose": {
          "type": "string",
          "description": "步骤目标"
        },
        "inputs": {
          "type": "array",
          "description": "步骤输入（可选）",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "description": "步骤产出（可选）",
          "items": { "type": "string" }
        }
      }
    }
  }
}
